# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.

# This file will be committed to version control, so make sure not to have any
# secrets in it. If you are cloning this repo, create a copy of this file named
# ".env" and populate it with your secrets.

# When adding additional environment variables, the schema in "/src/env.js"
# should be updated accordingly.

# Better Auth (https://better-auth.com)
# Generate a secret: openssl rand -base64 32
BETTER_AUTH_SECRET=""
# Base URL of your app (no trailing slash)
BETTER_AUTH_URL="http://localhost:3000"

# Azure AD (Microsoft Entra ID) – used by Better Auth social provider
# Create an app registration in https://portal.azure.com/ under Microsoft Entra ID > App registrations
# Redirect URI (Web): http://localhost:3000/api/auth/callback/microsoft (dev) or https://yourapp.com/api/auth/callback/microsoft (prod)
AZURE_AD_CLIENT_ID=""
AZURE_AD_CLIENT_SECRET=""
AZURE_AD_TENANT_ID=""

# Prisma
# https://www.prisma.io/docs/reference/database-reference/connection-urls#env
DATABASE_URL="postgresql://postgres:password@localhost:5432/seif"

# Cloudflare R2 (S3-compatible) – budget file uploads
# Create a bucket and API token at https://dash.cloudflare.com/ → R2
# Enable public access on the bucket (or use a custom domain), then set R2_PUBLIC_URL to the bucket’s public URL (e.g. https://pub-xxx.r2.dev, no trailing slash)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# Optional: show commit SHA in footer (e.g. set in CI)
# NEXT_PUBLIC_GIT_COMMIT_SHA=""
