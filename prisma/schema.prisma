// Better Auth core schema + custom User.role
// https://better-auth.com/docs/concepts/database

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  applications      SeifApplication[] @relation("ApplicationSubmitter")
  reviewedApplications SeifApplication[] @relation("ApplicationReviewer")
  submittedReports  SeifReport[]       @relation("ReportSubmitter")
  reviewedReports   SeifReport[]       @relation("ReportReviewer")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                   String    @id @default(cuid())
  userId               String
  accountId            String
  providerId           String
  accessToken          String?
  refreshToken         String?
  accessTokenExpiresAt DateTime?
  refreshTokenExpiresAt DateTime?
  scope                String?
  idToken              String?
  password             String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Organizations that can receive SEIF funding (CSA clubs, etc.)
model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  applications SeifApplication[]
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

// SEIF application - key fields for listing/filtering; full form data in formData JSON
model SeifApplication {
  id              String            @id @default(cuid())
  status          ApplicationStatus @default(SUBMITTED)
  amountRequested Decimal           @db.Decimal(10, 2)
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  submittedById   String?
  submittedBy     User?             @relation("ApplicationSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  submittedAt     DateTime          @default(now())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  // Full form payload for display and reporting
  formData        Json
  // Budget file path (from uploads)
  budgetFilePath  String?
  // Admin review metadata
  reviewedAt         DateTime?
  reviewedById       String?
  reviewedBy         User?     @relation("ApplicationReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewerComments   String?
  approvalConditions String?
  denialReason       String?
  // Approved amount (may differ from amountRequested); used for SEIF report pre-fill
  amountApproved     Decimal?  @db.Decimal(10, 2)
  // Post-approval SEIF report (one per application)
  report             SeifReport?
}

// Report status: tracking review and whether funds have been returned
enum ReportStatus {
  SUBMITTED             // Report submitted, awaiting coordinator review
  COMPLETE              // Reviewed and accepted; no funds to return
  PENDING_FUNDS_RETURN  // Coordinator determined they must return (some or all) funds
  FUNDS_RETURNED        // Applicant has returned the funds
}

// SEIF report submitted after an approved application (event/initiative completed)
model SeifReport {
  id                    String          @id @default(cuid())
  applicationId         String          @unique
  application           SeifApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  status                ReportStatus    @default(SUBMITTED)
  amountAllocated       Decimal         @db.Decimal(10, 2)
  amountSpent           Decimal         @db.Decimal(10, 2)
  underSpendExplanation String?
  descriptionActivities String
  finalBudgetFilePath   String
  receiptsFilePaths     Json            // array of uploaded receipt URLs
  receiptReviews        Json?           // per-receipt OCR results and admin review decisions
  submittedById         String?
  submittedBy           User?           @relation("ReportSubmitter", fields: [submittedById], references: [id], onDelete: SetNull)
  submittedAt           DateTime        @default(now())
  reviewedAt            DateTime?
  reviewedById          String?
  reviewedBy            User?           @relation("ReportReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  reviewerNotes         String?         // Internal notes (e.g. for funds-return tracking)
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
}
