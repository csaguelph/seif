// Better Auth core schema + custom User.role
// https://better-auth.com/docs/concepts/database

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  role          UserRole  @default(USER)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  applications  SeifApplication[]
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Account {
  id                   String    @id @default(cuid())
  userId               String
  accountId            String
  providerId           String
  accessToken          String?
  refreshToken         String?
  accessTokenExpiresAt DateTime?
  refreshTokenExpiresAt DateTime?
  scope                String?
  idToken              String?
  password             String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// Organizations that can receive SEIF funding (CSA clubs, etc.)
model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  applications SeifApplication[]
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  APPROVED
  REJECTED
}

// SEIF application - key fields for listing/filtering; full form data in formData JSON
model SeifApplication {
  id              String            @id @default(cuid())
  status          ApplicationStatus @default(SUBMITTED)
  amountRequested Decimal           @db.Decimal(10, 2)
  organizationId  String
  organization    Organization      @relation(fields: [organizationId], references: [id], onDelete: Restrict)
  submittedById   String?
  submittedBy     User?             @relation(fields: [submittedById], references: [id], onDelete: SetNull)
  submittedAt     DateTime          @default(now())
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  // Full form payload for display and reporting
  formData        Json
  // Budget file path (from uploads)
  budgetFilePath  String?
  // Admin review metadata
  reviewedAt         DateTime?
  reviewerComments   String?
  approvalConditions String?
  denialReason       String?
}
